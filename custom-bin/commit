#!/bin/bash
source /usr/local/lib/hubos/lib.sh
USER="$(hub_active_user)"
MSG="${*:-Manual commit $(date -u '+%Y-%m-%d %H:%M UTC')}"
printf 'Committing all repos for user: %s\n' "$USER"
for repo_dir in "$WORKSPACES/$USER"/*/; do
  [ -d "$repo_dir/.git" ] || continue
  hub_save_repo "$repo_dir" "$MSG" "$USER"
done
