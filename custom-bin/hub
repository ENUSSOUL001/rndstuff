#!/bin/bash
source /usr/local/lib/hubos/lib.sh
CURRENT_USER="$(hub_active_user)"

_read_multiline() {
  local title="$1" hint="$2"
  clear
  printf '+----------------------------------------------------------+\n'
  printf '|  %s\n' "$title"
  printf '+----------------------------------------------------------+\n'
  printf '%s\n\n' "$hint"
  printf '  Paste below. Press Enter, then Ctrl+D on a blank line when done.\n\n'
  cat
}

_confirm_secret() {
  local name="$1" value="$2"
  local preview="${value:0:80}"
  local len="${#value}"
  dialog --yesno \
    "Confirm push: $name\n\nPreview (first 80 chars):\n$preview\n\nTotal: $len chars\n\nProceed?" \
    14 66
}

_menu_secrets() {
  while true; do
    local REPO SCHOICE
    REPO="$(hub_github_repo)"
    SCHOICE=$(dialog --clear --title "Secret Manager" \
      --menu "Repo: ${REPO:-not set}" 20 66 7 \
      1 "Save PAT -> GH_SYNC_TOKEN" \
      2 "Save Qwen blob 1 -> CACHE_BLOB (paste JSON)" \
      3 "Save Qwen blob 2 -> CACHE_BLOB_2 (paste JSON)" \
      4 "Push a custom secret (single line)" \
      5 "Push a custom secret (multiline / JSON)" \
      6 "How does this work?" \
      7 "Back" \
      3>&1 1>&2 2>&3) || return
    case "$SCHOICE" in
      1)
        local v confirm
        v=$(dialog --clear --passwordbox \
          "GitHub PAT (classic, repo+workflow scope):" 9 58 3>&1 1>&2 2>&3)
        if [ -n "$v" ]; then
          confirm=$(dialog --clear --passwordbox \
            "Confirm PAT (type again):" 9 58 3>&1 1>&2 2>&3)
          if [ "$v" = "$confirm" ]; then
            hub_push_secret "GH_SYNC_TOKEN" "$v"
          else
            dialog --msgbox "PAT entries do not match. Not saved." 6 44
          fi
        fi
        ;;
      2)
        local v
        v=$(_read_multiline "CACHE_BLOB" \
          "  Paste the full JSON from ~/.qwen/oauth_creds_acc1.json")
        if [ -n "$v" ] && _confirm_secret "CACHE_BLOB" "$v"; then
          hub_push_secret "CACHE_BLOB" "$v"
        fi
        ;;
      3)
        local v
        v=$(_read_multiline "CACHE_BLOB_2" \
          "  Paste the full JSON from ~/.qwen/oauth_creds_acc2.json")
        if [ -n "$v" ] && _confirm_secret "CACHE_BLOB_2" "$v"; then
          hub_push_secret "CACHE_BLOB_2" "$v"
        fi
        ;;
      4)
        local sname sval confirm
        sname=$(dialog --clear --inputbox "Secret name (e.g. MY_API_KEY):" 8 52 3>&1 1>&2 2>&3)
        if [ -n "$sname" ]; then
          sval=$(dialog --clear --passwordbox "Secret value:" 8 52 3>&1 1>&2 2>&3)
          if [ -n "$sval" ]; then
            confirm=$(dialog --clear --passwordbox "Confirm value:" 8 52 3>&1 1>&2 2>&3)
            if [ "$sval" = "$confirm" ]; then
              hub_push_secret "$sname" "$sval"
            else
              dialog --msgbox "Values do not match. Not saved." 6 38
            fi
          fi
        fi
        ;;
      5)
        local sname sval
        sname=$(dialog --clear --inputbox "Secret name:" 8 52 3>&1 1>&2 2>&3)
        if [ -n "$sname" ]; then
          sval=$(_read_multiline "Custom: $sname" "  Paste the value below.")
          if [ -n "$sval" ] && _confirm_secret "$sname" "$sval"; then
            hub_push_secret "$sname" "$sval"
          fi
        fi
        ;;
      6)
        dialog --msgbox \
          "Secrets are encrypted with LibSodium and pushed\nto GitHub via REST API.\n\nAvailable automatically on the NEXT run.\nNeeds a classic PAT with repo scope.\nFine-grained PATs do NOT support secrets API.\n\nFor JSON blobs: paste full content.\nCtrl+D on a blank line finishes input." \
          14 60
        ;;
      7) return ;;
    esac
  done
}

_menu_repos() {
  local PAT
  PAT="$(hub_user_pat "$CURRENT_USER")"
  if [ -z "$PAT" ]; then
    dialog --msgbox "No PAT found for '$CURRENT_USER'.\nUse option 2 to add or switch user." 7 52
    return
  fi
  dialog --infobox "Fetching repositories for $CURRENT_USER..." 4 52
  local REPOS
  REPOS=$(curl -sf \
    -H "Authorization: token $PAT" \
    -H "Accept: application/vnd.github+json" \
    "https://api.github.com/user/repos?per_page=100&sort=updated&affiliation=owner,collaborator" \
    | jq -r '.[].full_name' 2>/dev/null)
  if [ -z "$REPOS" ]; then
    dialog --msgbox "Failed to fetch repos.\nCheck PAT has repo scope and is valid." 7 52
    return
  fi
  local OPTS=()
  while IFS= read -r r; do OPTS+=("$r" "->"); done <<< "$REPOS"
  local REPO_CHOICE
  REPO_CHOICE=$(dialog --clear --title "Your Repositories" \
    --menu "Select to clone or open:" 24 66 16 \
    "${OPTS[@]}" 3>&1 1>&2 2>&3) || return
  local SHORT="${REPO_CHOICE##*/}"
  local REPO_DIR="$WORKSPACES/$CURRENT_USER/$SHORT"
  if [ ! -d "$REPO_DIR/.git" ]; then
    dialog --infobox "Cloning $REPO_CHOICE ..." 4 52
    if ! git clone \
        "https://$CURRENT_USER:$PAT@github.com/$REPO_CHOICE.git" \
        "$REPO_DIR" >/dev/null 2>&1; then
      dialog --msgbox "Clone failed.\nCheck PAT has access to this repo." 7 50
      return
    fi
    git -C "$REPO_DIR" config user.name  "$CURRENT_USER"
    git -C "$REPO_DIR" config user.email "$(hub_user_email "$CURRENT_USER")"
  fi
  hub_set_repo "$REPO_DIR"
  clear
  printf '\e[1;32m'
  printf '+----------------------------------------------------------+\n'
  printf '|  Connected: %-42s |\n' "$SHORT"
  printf '|  Path:      %-42s |\n' "$REPO_DIR"
  printf '+----------------------------------------------------------+\n'
  printf '|  h             -> Hermes AI (runs in this dir)          |\n'
  printf '|  cdw           -> jump to this repo root                |\n'
  printf '|  go [name]     -> switch to another repo                |\n'
  printf '|  save [msg]    -> commit + push this repo               |\n'
  printf '|  override [m]  -> force push (--allow-empty)            |\n'
  printf '|  commit [msg]  -> commit all repos (current user)       |\n'
  printf '|  gcommit [msg] -> commit all repos (all users)          |\n'
  printf '|  gsave [msg]   -> global save: repos + system state     |\n'
  printf '|  secrets       -> manage GitHub secrets                 |\n'
  printf '|  links         -> show SSH / browser links              |\n'
  printf '|  hub           -> back to main menu                     |\n'
  printf '+----------------------------------------------------------+\n'
  printf '\e[0m\n'
  bash --rcfile <(cat ~/.bashrc; echo "cd '$REPO_DIR'")
}

_menu_users() {
  while true; do
    local USERS_LIST OPTS=() U_CHOICE
    USERS_LIST=$(ls -1 "$USERS_DIR" 2>/dev/null)
    while IFS= read -r u; do
      [ -n "$u" ] && OPTS+=("$u" "$([ "$u" = "$CURRENT_USER" ] && echo 'active' || echo 'switch')")
    done <<< "$USERS_LIST"
    OPTS+=("__add__" "+ Add new user")
    U_CHOICE=$(dialog --clear --title "User Profiles" \
      --menu "Active: $CURRENT_USER" 18 54 10 \
      "${OPTS[@]}" 3>&1 1>&2 2>&3) || return
    if [ "$U_CHOICE" = "__add__" ]; then
      local NEW_USER NEW_PAT NEW_EMAIL PROFILE
      NEW_USER=$(dialog --clear --inputbox "GitHub Username:" 8 48 3>&1 1>&2 2>&3)
      [ -z "$NEW_USER" ] && return
      NEW_PAT=$(dialog --clear --passwordbox \
        "GitHub PAT (repo + workflow scopes, classic PAT):" 10 54 3>&1 1>&2 2>&3)
      [ -z "$NEW_PAT" ] && return
      dialog --infobox "Verifying credentials..." 4 48
      PROFILE=$(curl -sf -H "Authorization: token $NEW_PAT" \
        https://api.github.com/user 2>/dev/null)
      if [ -z "$PROFILE" ] || [ "$(echo "$PROFILE" | jq -r '.login // empty')" = "" ]; then
        dialog --msgbox "ERROR: Invalid credentials.\nCheck PAT is valid and not expired." 7 54
        return
      fi
      NEW_EMAIL=$(echo "$PROFILE" | jq -r '.email // empty')
      if [ -z "$NEW_EMAIL" ] || [ "$NEW_EMAIL" = "null" ]; then
        NEW_EMAIL=$(dialog --clear --inputbox \
          "Email not public. Enter git commit email:" 9 54 3>&1 1>&2 2>&3)
        [ -z "$NEW_EMAIL" ] && NEW_EMAIL="${NEW_USER}@cloud.local"
      fi
      mkdir -p "$USERS_DIR/$NEW_USER"
      printf '%s' "$NEW_PAT"   > "$USERS_DIR/$NEW_USER/pat"
      printf '%s' "$NEW_EMAIL" > "$USERS_DIR/$NEW_USER/email"
      CURRENT_USER="$NEW_USER"
      hub_set_user "$CURRENT_USER"
      hub_ensure_window "$CURRENT_USER"
      if dialog --yesno \
        "User '$NEW_USER' added!\n\nSave PAT as GH_SYNC_TOKEN in GitHub Secrets?\nMakes it available on the next run." \
        10 58; then
        hub_push_secret "GH_SYNC_TOKEN" "$NEW_PAT" "$NEW_PAT"
      fi
    elif [ -n "$U_CHOICE" ]; then
      CURRENT_USER="$U_CHOICE"
      hub_set_user "$CURRENT_USER"
      hub_ensure_window "$CURRENT_USER"
      dialog --msgbox "Switched to '$CURRENT_USER'" 5 36
      return
    fi
  done
}

_save_all() {
  dialog --infobox "Saving all open repositories..." 4 42
  local results=""
  for repo_dir in "$WORKSPACES/$CURRENT_USER"/*/; do
    [ -d "$repo_dir/.git" ] || continue
    local out
    out=$(hub_save_repo "$repo_dir" "Manual cloud save" "$CURRENT_USER")
    results+="$out\n"
  done
  dialog --msgbox "Save complete:\n\n${results:-No repos found.}" 14 58
}

_reauth_account() {
  local acc="$1" secret_name="$2"
  while true; do
    clear
    printf '+----------------------------------------------------------+\n'
    printf '|  Reauth: %s -> %s\n' "$acc" "$secret_name"
    printf '+----------------------------------------------------------+\n'
    printf '  A URL and QR code will appear below.\n'
    printf '  Open the URL in your browser and log in.\n'
    printf '  Terminal waits. Press Ctrl+C to cancel.\n\n'
    qwen-proxy auth add "$acc"
    local result=$?
    echo ""
    if [ $result -eq 0 ]; then
      local creds_file="$HOME/.qwen/oauth_creds_${acc}.json"
      if [ -f "$creds_file" ]; then
        local creds
        creds=$(cat "$creds_file")
        if dialog --yesno \
          "Auth for $acc succeeded!\n\nPush credentials to GitHub secret '$secret_name'?\nSaves them for the next workflow run." \
          10 60; then
          hub_push_secret "$secret_name" "$creds"
        fi
      else
        dialog --msgbox "Auth succeeded but cred file not found:\n$creds_file" 8 60
      fi
      break
    else
      if dialog --yesno "Auth for $acc failed or cancelled.\nRetry?" 7 44; then
        continue
      else
        break
      fi
    fi
  done
}

_menu_reauth() {
  local SELECTED
  SELECTED=$(dialog --clear --title "Reauth Proxy Accounts" \
    --checklist "Select accounts to re-authenticate:" 12 58 3 \
    "acc1" "Account 1  (saves to CACHE_BLOB)" "on" \
    "acc2" "Account 2  (saves to CACHE_BLOB_2)" "on" \
    3>&1 1>&2 2>&3) || return
  SELECTED=$(printf '%s' "$SELECTED" | tr -d '"' | tr ' ' '\n' | grep -v '^$')
  if [ -z "$SELECTED" ]; then
    dialog --msgbox "No accounts selected." 5 32
    return
  fi
  while IFS= read -r acc; do
    [ -z "$acc" ] && continue
    local secret_name="CACHE_BLOB"
    [ "$acc" = "acc2" ] && secret_name="CACHE_BLOB_2"
    _reauth_account "$acc" "$secret_name"
  done <<< "$SELECTED"
  dialog --msgbox "Reauth complete.\nProxy will use new credentials on next request." 8 52
}

hub_ensure_window "$CURRENT_USER"

while true; do
  CURRENT_USER="$(hub_active_user)"
  hub_print_links
  CHOICE=$(dialog --clear \
    --title "Cloud Hub OS  |  $SESSION_LABEL" \
    --menu "User: $CURRENT_USER  |  $(date '+%a %H:%M')  |  type 'hub' anytime to return" \
    26 66 11 \
    1  "Select / Clone Repository" \
    2  "Switch / Add User" \
    3  "Manage GitHub Secrets" \
    4  "Save All Open Repos" \
    5  "Global Save (repos + system state)" \
    6  "Show Access Links" \
    7  "Tmux Window List" \
    8  "Proxy Status and Models" \
    9  "Reauth Proxy Accounts" \
    10 "Drop to Shell" \
    11 "Exit Hub" \
    3>&1 1>&2 2>&3)
  [ $? -ne 0 ] && CHOICE=10
  case "$CHOICE" in
    1)  _menu_repos ;;
    2)  _menu_users ;;
    3)  _menu_secrets ;;
    4)  _save_all ;;
    5)
      clear
      echo "Running global save..."
      gsave "Manual global save $(date -u '+%Y-%m-%d %H:%M UTC')"
      read -rp "Press Enter to return to menu..." _dummy
      ;;
    6)
      clear
      hub_print_links
      read -rp "Press Enter to return to menu..." _dummy
      ;;
    7)
      clear
      tmux list-windows -t "$TMUX_SESSION" 2>/dev/null \
        || echo "(not in a tmux session)"
      read -rp "Press Enter to return to menu..." _dummy
      ;;
    8)
      clear
      echo "=== Proxy Current Status ==="
      if hub_proxy_alive; then
        echo "Running: YES  ($PROXY_URL/v1)"
        echo ""
        echo "Models:"
        hub_proxy_models | sed 's/^/  - /'
        echo ""
        echo "Account status:"
        hub_proxy_account_status | sed 's/^/  /'
        if hub_proxy_any_invalid; then
          echo ""
          echo "WARNING: One or more accounts are INVALID."
          echo "Use option 9 (Reauth Proxy Accounts) to fix."
        fi
      else
        echo "Running: NO"
      fi
      echo ""
      echo "=== Recent Proxy Log (last 25 lines) ==="
      tail -25 ~/proxy.log 2>/dev/null || echo "(no proxy log)"
      echo ""
      read -rp "Press Enter to return to menu..." _dummy
      ;;
    9)  _menu_reauth ;;
    10)
      clear
      cat << 'SHELLTIP'
+------------------------------------------------------------------+
|  h             -> Hermes AI (runs in your current directory)    |
|  cdw           -> cd to current repo root                       |
|  go [name]     -> switch repos (fuzzy or picker)                |
|  save [msg]    -> commit and push current repo                  |
|  override [m]  -> force push (--allow-empty)                    |
|  commit [msg]  -> commit all repos (current user)               |
|  gcommit [msg] -> commit all repos (all users)                  |
|  gsave [msg]   -> global save: repos + system state to branch   |
|  secrets       -> push secrets to GitHub                        |
|  links         -> show SSH / browser access links               |
|  hub           -> back to main menu                             |
|                                                                  |
|  Scroll in tmux (SSH or web terminal):                           |
|  Ctrl+B [      enter scroll mode                                |
|  Arrow keys    scroll line by line                              |
|  PgUp / PgDn   scroll page by page                             |
|  q             exit scroll mode                                 |
|  Two-finger swipe works in Termux with mouse on                 |
+------------------------------------------------------------------+
SHELLTIP
      break
      ;;
    11)
      clear
      echo "Session stays alive in background."
      exit 0
      ;;
  esac
done
