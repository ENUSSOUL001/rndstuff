#!/bin/bash
source /usr/local/lib/hubos/lib.sh
_push_custom() {
  local SNAME SVAL
  SNAME=$(dialog --clear --inputbox "Secret name:" 8 50 3>&1 1>&2 2>&3) || return
  SVAL=$(dialog --clear --passwordbox "Secret value:" 8 50 3>&1 1>&2 2>&3) || return
  [ -n "$SNAME" ] && [ -n "$SVAL" ] && hub_push_secret "$SNAME" "$SVAL"
}
while true; do
  CHOICE=$(dialog --clear --title "Secret Manager" \
    --menu "Repo: $(hub_github_repo)" 14 60 5 \
    1 "Push GH_SYNC_TOKEN (PAT)" \
    2 "Push CACHE_BLOB" \
    3 "Push CACHE_BLOB_2" \
    4 "Push custom secret" \
    5 "Exit" \
    3>&1 1>&2 2>&3) || break
  case "$CHOICE" in
    1) v=$(dialog --clear --passwordbox "PAT:" 8 50 3>&1 1>&2 2>&3); [ -n "$v" ] && hub_push_secret "GH_SYNC_TOKEN" "$v" ;;
    2) v=$(dialog --clear --inputbox "CACHE_BLOB:" 10 60 3>&1 1>&2 2>&3); [ -n "$v" ] && hub_push_secret "CACHE_BLOB" "$v" ;;
    3) v=$(dialog --clear --inputbox "CACHE_BLOB_2:" 10 60 3>&1 1>&2 2>&3); [ -n "$v" ] && hub_push_secret "CACHE_BLOB_2" "$v" ;;
    4) _push_custom ;;
    5) break ;;
  esac
done
